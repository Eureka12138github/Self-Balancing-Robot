# ============================================================
# VSCode 配置文件
# ============================================================
# 数据库和缓存
.vscode/.browse.c_cpp.db*
.vscode/ipch/
.vscode/UnityLinker.data
.vscode/*.db

# 工作区数据（可选忽略）
.vscode/.vscode/

# 扩展推荐（建议保留，不忽略）
# .vscode/extensions.json

# 任务配置（建议保留，不忽略）
# .vscode/tasks.json

# 调试配置（建议保留，不忽略）
# .vscode/launch.json

# C/C++ 属性配置（建议保留，不忽略）
# .vscode/c_cpp_properties.json

# 编辑器临时文件
.vscode/*.tmp
.vscode/*.log

